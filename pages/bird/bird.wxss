/*注意设置顶层元素的宽高*/
page,view {
  width: 100%;
  height: 100%;
}

/*canvas占屏幕一半高度*/
canvas {
  border: 1px solid #d3d3d3;
  background-color: #f1f1f1;
  border-radius: 5px;
  width:100%;
  height:50%;
}

button {
  margin-top: 50px;
  padding: 25px;
  height: 100px;
  border-radius: 100px;
  width: 70%;
}
.userinfo-avatar {
  width: 128rpx;
  height: 128rpx;
  margin: 20rpx;
  margin-right: 100rpx;
  margin-left:50rpx;
  border-radius: 50%;
}

.userinfo-nickname {
  color: #aaa;
}

.score {
    display: flex;
    align-items: center;
    
}

.scorebox{
  background-color: #b9ab9f;
  color:#ffffff;
  padding:10rpx;
}
