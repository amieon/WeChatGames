
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background-color: #f0f2f5;
}



.userinfo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 50rpx;
  margin-bottom: 50rpx;
}

.userinfo-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
}

.userinfo-nickname {
  font-size: 32rpx;
  color: #333;
}

.usermotto {
  margin-bottom: 40rpx;
}

.user-motto {
  font-size: 28rpx;
  color: #666;
}

.button-grid {
  width: 600rpx;
  height: 900rpx; 
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: repeat(3, 1fr); 
  gap: 20rpx;
  top: -50rpx;
}


.game-button {
  width: 280rpx;
  height: 280rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #ffffff, #e0e0e0);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 0;
}

.image-container {
  align-self: center;
  width: 70%;
  height: 70%;
  background-color: #f8f9fa;
}

.image-container image {
  width: 100%;
  height: 100%;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
}

.text-container {
  width: 100%;
  height: 30%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: white;
  color: black;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border-bottom-left-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
}

/* Positioning */
.top-left {
  grid-column: 1;
  grid-row: 1;
}

.top-right {
  grid-column: 2;
  grid-row: 1;
}

.bottom-left {
  grid-column: 1;
  grid-row: 2;
}

.bottom-right {
  grid-column: 2;
  grid-row: 2;
}

/* Responsive Design */
@media (max-width: 750rpx) {
  .container {
    padding: 10rpx;
  }

  .button-grid {
    width: 100%;
    height: auto;
    grid-template-columns: 1fr;
    grid-template-rows: repeat(4, 1fr);
    gap: 10rpx;
  }

  .game-button {
    width: 100%;
    height: 200rpx;
  }

  .top-left,
  .top-right,
  .bottom-left,
  .bottom-right {
    grid-column: 1;
  }

  .top-left {
    grid-row: 1;
  }

  .top-right {
    grid-row: 2;
  }

  .bottom-left {
    grid-row: 3;
  }

  .bottom-right {
    grid-row: 4;
  }

  .tab-container {
    width: 100%;
    height: 300rpx; /* 调整高度，容纳排行榜 */
    margin-top: 20rpx;
  }
  
  .tab-swiper {
    width: 100%;
    height: 100%;
  }
  
  .tab-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: #ffffff;
    border-radius: 20rpx;
    padding: 20rpx;
    box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  }
  
  .tab-title {
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
    color: #333;
  }
  
  .game-desc {
    font-size: 28rpx;
    color: #666;
    text-align: left;
    line-height: 40rpx;
  }
  
  .rank-list {
    width: 100%;
    max-height: 200rpx;
    overflow-y: auto; /* 排行榜可滚动 */
  }
  
  .rank-item {
    font-size: 28rpx;
    color: #333;
    padding: 10rpx 0;
    border-bottom: 1rpx solid #eee;
  }
  
  /* 响应式 */
  @media (max-width: 750rpx) {
    .container {
      padding: 10rpx;
    }
  
    .button-grid {
      width: 100%;
      height: auto;
      grid-template-columns: 1fr;
      grid-template-rows: repeat(6, 1fr); /* 6游戏 */
      gap: 10rpx;
    }
  
    .game-button {
      width: 100%;
      height: 200rpx;
    }
  
    .tab-container {
      height: 400rpx; /* 小屏加高 */
    }
    }
}