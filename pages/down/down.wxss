/*注意设置顶层元素的宽高*/
page,view {
  width: 100%;
  height: 100%;
}

/*canvas占屏幕一半高度*/
canvas {
  border: 1px solid #d3d3d3;
  background-color: #f1f1f1;
  border-radius: 5px;
  width:100%;
  height:50%;
}

button {
  margin-top: 50px;
  padding: 25px;
  height: 100px;
  border-radius: 100px;
  width: 50%;
}
.userinfo-avatar {
  width: 128rpx;
  height: 128rpx;
  margin: 20rpx;
  margin-right: 100rpx;
  margin-left:50rpx;
  border-radius: 50%;
}

.userinfo-nickname {
  color: #aaa;
}

.score {
    display: flex;
    align-items: center;
    
}

.scorebox{
  background-color: #b9ab9f;
  color:#ffffff;
  padding:10rpx;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background-color: #f0f2f5;
}



.userinfo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 250rpx;
  margin-bottom: 5rpx;
}

.userinfo-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
}

.userinfo-nickname {
  font-size: 32rpx;
  color: #333;
}

.usermotto {
  margin-bottom: 40rpx;
}

.user-motto {
  font-size: 28rpx;
  color: #666;
}

.button-grid {
  width: 600rpx;
  height: 900rpx; 
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: repeat(3, 1fr); 
  gap: 20rpx;
}


.game-button {
  width: 340rpx;
  height: 100rpx;
  border-radius: 20rpx;
  margin-left: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 0;
}

.image-container {
  align-self: center;
  width: 70%;
  height: 70%;
  background-color: #f8f9fa;
}

.image-container image {
  width: 100%;
  height: 100%;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
}

.text-container {
  width: 100%;
  height: 30%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: white;
  color: black;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border-bottom-left-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
}

/* Positioning */
.top-left {
  grid-column: 1;
  grid-row: 1;
}

.top-right {
  grid-column: 2;
  grid-row: 1;
}

.bottom-left {
  grid-column: 1;
  grid-row: 2;
}

.bottom-right {
  grid-column: 2;
  grid-row: 2;
}

/* Responsive Design */
@media (max-width: 750rpx) {
  .container {
    padding: 10rpx;
  }

  .button-grid {
    width: 100%;
    height: auto;
    grid-template-columns: 1fr;
    grid-template-rows: repeat(4, 1fr);
    gap: 10rpx;
  }

  .game-button {
    width: 100%;
    height: 200rpx;
  }

  .top-left,
  .top-right,
  .bottom-left,
  .bottom-right {
    grid-column: 1;
  }

  .top-left {
    grid-row: 1;
  }

  .top-right {
    grid-row: 2;
  }

  .bottom-left {
    grid-row: 3;
  }

  .bottom-right {
    grid-row: 4;
  }
}